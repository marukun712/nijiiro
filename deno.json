{
	"tasks": {
		"start": "deno run --allow-net --allow-env --allow-read --allow-write --allow-sys --env src/server/main.ts",
		"dev": "deno run --watch --allow-net --allow-env --allow-read --allow-write --allow-sys --env src/server/main.ts",
		"build": "deno run --allow-env --allow-read --allow-write --allow-sys --env scripts/build.ts",
		"setup": "deno run -A scripts/setup.ts",
		"check": "deno check && deno run -A npm:@biomejs/biome check --write ./",
		"check:unsafe": "deno check && deno run -A npm:@biomejs/biome check --write --unsafe ./"
	},
	"imports": {
		"@atcute/atproto": "npm:@atcute/atproto@^4.0.3",
		"@atcute/car": "npm:@atcute/car@^6.0.2",
		"@atcute/cbor": "npm:@atcute/cbor@^2.3.6",
		"@atcute/cid": "npm:@atcute/cid@^2.4.2",
		"@atcute/crypto": "npm:@atcute/crypto@^2.4.4",
		"@atcute/lexicons": "npm:@atcute/lexicons@^2.0.3",
		"@atcute/mst": "npm:@atcute/mst@^1.0.3",
		"@atcute/repo": "npm:@atcute/repo@^1.0.2",
		"@atcute/tid": "npm:@atcute/tid@^1.1.4",
		"@atcute/xrpc-server": "npm:@atcute/xrpc-server@^2.0.2",
		"@atcute/xrpc-server/middlewares/cors": "npm:@atcute/xrpc-server@^2.0.2/middlewares/cors",
		"@atcute/xrpc-server/auth": "npm:@atcute/xrpc-server@^2.0.2/auth",
		"@atcute/xrpc-server-deno": "npm:@atcute/xrpc-server-deno@^2.0.1",
		"@std/fs": "jsr:@std/fs@^1.0.24",
		"jose": "npm:jose@^6.2.3",
		"@std/assert": "jsr:@std/assert@1",
		"@std/encoding": "jsr:@std/encoding@^1.0.11",
		"@std/path": "jsr:@std/path@^1.1.6",
		"zod": "npm:zod@^4.4.3"
	}
}
